PORT=5175
# Optional in dev (server allows any localhost origin); required in production.
CLIENT_ORIGIN=http://localhost:5173

# Set this to a long random string in production
JWT_SECRET=dev-secret-change-me

# Put your key here (do NOT hardcode in code). Optional in dev; required for weather features.
OPENWEATHER_API_KEY=your_openweather_key_here

# SQLite file path (relative to server/)
SQLITE_PATH=./data/app.db

